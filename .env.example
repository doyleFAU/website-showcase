# Supabase - Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Contact form email (Supabase Edge Function secrets — NOT in Vercel frontend)
# Set these in Supabase → Edge Functions → contact-submit → Secrets:
#   RESEND_API_KEY=re_xxxxxxxx
#   CONTACT_NOTIFY_EMAIL=you@yourdomain.com
#   CONTACT_FROM_EMAIL=Vervio <onboarding@resend.dev>
# Optional: use a verified domain in Resend for production, e.g.:
#   CONTACT_FROM_EMAIL=Vervio <hello@yourdomain.com>

# Optional - for canonical URLs / sitemap when building pages
# SITE_URL=https://website-showcase-lemon.vercel.app

# Optional - Google Search Console verification
# GOOGLE_SITE_VERIFICATION=
